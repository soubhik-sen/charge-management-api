# Database used by Alembic and the API.
DATABASE_URL=postgresql+psycopg://charge_user:charge_password@localhost:5432/charge_management

# Production default: validate JWTs issued for this API.
AUTH_MODE=jwt
JWT_ISSUER=https://identity.example.com/
JWT_AUDIENCE=charge-management-api
JWT_JWKS_URL=https://identity.example.com/.well-known/jwks.json
JWT_ALGORITHMS=RS256
JWT_ROLES_CLAIM=roles
JWT_TENANT_CLAIM=tenant_id
JWT_LEEWAY_SECONDS=30

# For HS256 deployments only. Prefer JWT_JWKS_URL and asymmetric keys in production.
# JWT_SHARED_SECRET=replace-with-a-secret-from-your-secret-manager

# Local smoke tests may use AUTH_MODE=development. Never use it in production.
